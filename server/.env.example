MONGO_URI=mongodb://localhost:27017/curious-chappal
PORT=5001
# CORS allow-list. By default index.js allows localhost / 127.0.0.1 (any port)
# and curious-engine.{test,local,pro}. To lock it down in production, set
# CLIENT_ORIGINS to a comma-separated list of exact origins; when set, only those
# are allowed.
# CLIENT_ORIGINS=https://app.example.com,https://example.com
# Vite runs on port 5174 (see client/vite.config.ts).
